.TH "HASHER" "1" "May 2026" "ccc" "User Commands"

.SH NAME
hasher-man - Generate or install man pages


.SH SYNOPSIS
\fBhasher man [flags]\fP


.SH DESCRIPTION
man emits roff-formatted man pages for hasher and each subcommand.
Pages are generated on demand from the live cobra command tree, so they
always reflect the current binary's flags and help text.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for man


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--algo\fP="argon2"
	hash algorithm: bcrypt or argon2

.PP
\fB--config\fP=""
	config file (default: $XDG_CONFIG_HOME/hasher/hasher.yaml)

.PP
\fB--output\fP="text"
	output format: text or json


.SH SEE ALSO
\fBhasher(1)\fP, \fBhasher-man-generate(1)\fP, \fBhasher-man-install(1)\fP


