.TH "HASHER" "1" "May 2026" "ccc" "User Commands"

.SH NAME
hasher-completion-install - Install the completion script for the current shell


.SH SYNOPSIS
\fBhasher completion install [flags]\fP


.SH DESCRIPTION
Install detects $SHELL (or accepts --shell ) and writes the completion
script to the conventional XDG location:

.PP
bash         $XDG_DATA_HOME/bash-completion/completions/hasher
  zsh          $XDG_DATA_HOME/zsh/site-functions/_hasher
  fish         $XDG_CONFIG_HOME/fish/completions/hasher.fish
  powershell   prints the script with install instructions

.PP
Use --print to write the script to stdout instead.


.SH OPTIONS
\fB--force\fP[=false]
	overwrite an existing completion file

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for install

.PP
\fB--print\fP[=false]
	print the script to stdout instead of installing

.PP
\fB--shell\fP=""
	shell name (bash, zsh, fish, powershell); default: auto-detect from $SHELL


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--algo\fP="argon2"
	hash algorithm: bcrypt or argon2

.PP
\fB--config\fP=""
	config file (default: $XDG_CONFIG_HOME/hasher/hasher.yaml)

.PP
\fB--output\fP="text"
	output format: text or json


.SH EXAMPLE
.EX
  # Auto-detect shell, write to XDG location
  hasher completion install

  # Explicit shell, dump to stdout
  hasher completion install --shell zsh --print > _hasher
.EE


.SH SEE ALSO
\fBhasher-completion(1)\fP


