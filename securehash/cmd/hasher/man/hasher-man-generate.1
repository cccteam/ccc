.SH NAME
hasher-man-generate - Write man pages into 


.SH SYNOPSIS
\fBhasher man generate  [flags]\fP


.SH DESCRIPTION
Write hasher.1 and one .1 file per subcommand into \&.
The directory is created if it does not exist.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for generate


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--algo\fP="argon2"
	hash algorithm: bcrypt or argon2

.PP
\fB--config\fP=""
	config file (default: $XDG_CONFIG_HOME/hasher/hasher.yaml)

.PP
\fB--output\fP="text"
	output format: text or json


.SH EXAMPLE
.EX
  hasher man generate ./man
.EE


